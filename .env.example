# Example environment variables for Notion Tree application
# Do not provide real credentials in this file

# App environment
NODE_ENV=development
PORT=3000

# Prisma database connection
DATABASE_URL="mysql://<user>:<password>@localhost:3306/notion_tree"
SHADOW_DATABASE_URL="mysql://<user>:<password>@localhost:3306/notion_tree_shadow"

# AWS Cognito (JWT verification)
COGNITO_USER_POOL_ID="us-east-1_XXXXXX"
COGNITO_REGION="us-east-1"
COGNITO_APP_CLIENT_ID="xxxxxxxxxxxxxxxxxxxx"
